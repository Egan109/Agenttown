{
  "name": "agenttown",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A top-down 2D emergent-society simulation where every villager is an autonomous agent with traits, needs, memories, relationships and an LLM-driven inner mind.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "smoke": "esbuild scripts/smoke.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/agenttown-smoke.mjs && node node_modules/.cache/agenttown-smoke.mjs",
    "reflcheck": "esbuild scripts/reflcheck.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/agenttown-reflcheck.mjs && node node_modules/.cache/agenttown-reflcheck.mjs",
    "llmcheck": "esbuild scripts/llmcheck.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/agenttown-llmcheck.mjs && node node_modules/.cache/agenttown-llmcheck.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}